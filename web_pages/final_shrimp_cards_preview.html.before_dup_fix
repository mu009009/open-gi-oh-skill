            "🌀 潜行：无法被选中为目标",
            "🔥 剧毒：造成的伤害直接消灭目标",
            "💫 风怒：每回合可以攻击两次",
            "🛡️ 免疫：免疫所有伤害和效果",
            "🌀 冻结：使目标下回合无法攻击",
            "🌟 光环：为友方单位提供增益",
            "💥 超杀：溢出伤害转化为额外效果",
            "🔄 复生：第一次死亡后以1点生命值复活"
        ];
        
        // 为每张卡牌分配效果文本
        function assignEffectTexts(cards) {
            return cards.map(card => {
                // 根据性格选择不同的效果类型
                let effectPool = [...effectTexts];
                
                // 性格特定效果偏好
                if (card.personality === '勇敢') {
                    effectPool = effectPool.filter(effect => 
                        effect.includes('冲锋') || effect.includes('连击') || effect.includes('风怒')
                    );
                } else if (card.personality === '智慧') {
                    effectPool = effectPool.filter(effect => 
                        effect.includes('圣盾') || effect.includes('免疫') || effect.includes('光环')
                    );
                } else if (card.personality === '狡猾') {
                    effectPool = effectPool.filter(effect => 
                        effect.includes('潜行') || effect.includes('剧毒') || effect.includes('冻结')
                    );
                } else if (card.personality === '沉稳') {
                    effectPool = effectPool.filter(effect => 
                        effect.includes('嘲讽') || effect.includes('亡语') || effect.includes('复生')
                    );
                } else if (card.personality === '狂野') {
                    effectPool = effectPool.filter(effect => 
                        effect.includes('超杀') || effect.includes('剧毒') || effect.includes('连击')
                    );
                }
                
                // 如果池子空了，用默认池
                if (effectPool.length === 0) {
                    effectPool = effectTexts;
                }
                
                // 随机选择效果
                const randomEffect = effectPool[Math.floor(Math.random() * effectPool.length)];
                
                return {
                    ...card,
                    effect_text: randomEffect
                };
            });
        }
        
        // 初始化时分配效果文本
        allCards = assignEffectTexts(allCards);
        
        // 筛选卡牌
        function filterCards() {
            const personality = document.getElementById('personalityFilter').value;
            const wish = document.getElementById('wishFilter').value;
            const aesthetic = document.getElementById('aestheticFilter').value;
            const cost = document.getElementById('costFilter').value;
            const rarity = document.getElementById('rarityFilter').value;
            
            filteredCards = allCards.filter(card => {
                if (personality !== 'all' && card.personality !== personality) return false;
                if (wish !== 'all' && card.wish !== wish) return false;
                if (aesthetic !== 'all' && card.aesthetic !== aesthetic) return false;
                if (cost !== 'all' && card.cost !== parseInt(cost)) return false;
                if (rarity !== 'all' && card.rarity !== rarity) return false;
                return true;
            });
            
            // 更新筛选状态
            const activeFilters = [
                personality !== 'all' ? `${personalityIcons[personality]} ${personality}` : null,
                wish !== 'all' ? `✨ ${wish}` : null,
                aesthetic !== 'all' ? `🎨 ${aesthetic}` : null,
                cost !== 'all' ? `💰 ${cost}费` : null,
                rarity !== 'all' ? `⭐ ${rarity}` : null
            ].filter(Boolean);
            
            const filterStatus = activeFilters.length > 0 ? 
                `筛选条件: ${activeFilters.join(' | ')} | 显示 ${filteredCards.length} 张卡牌` :
                `显示全部 ${filteredCards.length} 张卡牌`;
            
            document.getElementById('filterStatus').textContent = filterStatus;
            
            displayCards();
        }
        
        // 重置筛选
        function resetFilters() {
            document.getElementById('personalityFilter').value = 'all';
            document.getElementById('wishFilter').value = 'all';
            document.getElementById('aestheticFilter').value = 'all';
            document.getElementById('costFilter').value = 'all';
            document.getElementById('rarityFilter').value = 'all';
            
            filterCards();
        }
        
        // 切换单个卡牌的效果/故事
        function toggleEffect(cardId) {
            const toggleBtn = document.querySelector(`[data-card-id="${cardId}"] .toggle-icon`);
            const contentDiv = document.getElementById(`content_${cardId}`);
            
            if (toggleBtn.classList.contains('flipped')) {
                // 切换到效果
                toggleBtn.classList.remove('flipped');
                contentDiv.innerHTML = `
                    <div class="effect-text effect-default">
                        ${allCards.find(card => card.id === cardId).effect_text}
                    </div>
                `;
            } else {
                // 切换到故事
                toggleBtn.classList.add('flipped');
                const card = allCards.find(card => card.id === cardId);
                contentDiv.innerHTML = `
                    <div class="effect-text story-text">
                        ${card.description}
                    </div>
                `;
            }
        }
        
        // 切换所有卡牌的效果/故事
        function toggleAllEffects() {
            allShowingEffect = !allShowingEffect;
            const toggleBtns = document.querySelectorAll('.toggle-icon');
            const contentDivs = document.querySelectorAll('[id^="content_"]');
            
            toggleBtns.forEach(btn => {
                if (allShowingEffect) {
                    btn.classList.remove('flipped');
                } else {
                    btn.classList.add('flipped');
                }
            });
            
            contentDivs.forEach(div => {
                const cardId = div.id.replace('content_', '');
                const card = allCards.find(card => card.id === cardId);
                
                if (allShowingEffect) {
                    div.innerHTML = `
                        <div class="effect-text effect-default">
                            ${card.effect_text}
                        </div>
                    `;
                } else {
                    div.innerHTML = `
                        <div class="effect-text story-text">
                            ${card.description}
                        </div>
                    `;
                }
            });
        }
        
        // 生成卡牌HTML
        function generateCardHTML(card) {
            const personalityIcon = personalityIcons[card.personality];
            const borderClass = personalityBorderClasses[card.personality];
            const rarityClass = rarityClasses[card.rarity];
            
            return `
            <div class="shrimp-card ${borderClass}">
                <!-- 卡牌顶部区域 -->
                <div class="card-top-bar">
                    <!-- 左边：费用 -->
                    <div class="card-cost">${card.cost}</div>
                    
                    <!-- 中间：名称 -->
                    <div class="card-center">
                        <div class="card-name">${card.name}</div>
                    </div>
                    
                    <!-- 右边：稀有度 + 性格 -->
                    <div class="card-right">
                        <div class="rarity-badge ${rarityClass}">
                            ${card.rarity}
                        </div>
                        <div class="personality-badge">
                            ${personalityIcon} ${card.personality}
                        </div>
                    </div>
                </div>
                
                <!-- 核心数值区域 -->
                <div class="card-core-stats">
                    <div class="stat-primary">
                        <div class="stat-value-primary attack-value">${card.attack}</div>
                        <div class="stat-label-primary">攻击力</div>
                    </div>
                    
                    <div class="stat-primary">
                        <div class="stat-value-primary health-value">${card.health}</div>
                        <div class="stat-label-primary">生命值</div>
                    </div>
                </div>
                
                <!-- 战斗力显示 -->
                <div class="combat-display">
                    <div class="combat-label">战斗力</div>
                    <div class="combat-value">${card.combat_value.toFixed(1)}</div>
                </div>
                
                <!-- 虾虾画面区域 (1:1比例) -->
                <div class="card-image-area">
                    <div class="image-placeholder">
                        <div class="image-placeholder-icon">🦐</div>
                        <div>虾虾卡画面区域</div>
                        <div style="font-size: 0.8rem; margin-top: 5px;">1:1 比例</div>
                    </div>
                </div>
                
                <!-- 属性区域 -->
                <div class="card-attributes">
                    <div class="attribute-badge wish-badge">
                        ✨ ${card.wish}
                    </div>
                    <div class="attribute-badge aesthetic-badge">
                        🎨 ${card.aesthetic}
                    </div>
                </div>
                
                <!-- 交互效果区域 -->
                <div class="card-effect-area">
                    <button class="effect-toggle" data-card-id="${card.id}" onclick="toggleEffect('${card.id}')">
                        <div class="toggle-label">
                            <span>${allShowingEffect ? '🔄 效果' : '📖 故事'}</span>
                        </div>
                        <div class="toggle-icon">▼</div>
                    </button>
                    <div id="content_${card.id}" class="effect-content">
                        <div class="effect-text effect-default">
                            ${card.effect_text}
                        </div>
                    </div>
                </div>
            </div>
            `;
        }
        
        // 显示卡牌
        function displayCards() {
            const cardGrid = document.getElementById('cardGrid');
            
            if (filteredCards.length === 0) {
                cardGrid.innerHTML = `
                    <div class="empty-state">
                        <h3>🦐 没有找到匹配的卡牌</h3>
                        <p>请尝试调整筛选条件</p>
                        <button class="control-btn" onclick="resetFilters()" style="margin-top: 20px;">
                            显示全部卡牌
                        </button>
                    </div>
                `;
                return;
            }
            
            const cardsHtml = filteredCards.map(card => generateCardHTML(card)).join('');
            cardGrid.innerHTML = cardsHtml;
        }
        
        // 初始化
        document.addEventListener('DOMContentLoaded', function() {
            filterCards();
            
            // 添加一些动画效果
            setTimeout(() => {
                const cards = document.querySelectorAll('.shrimp-card');
                cards.forEach((card, index) => {
                    card.style.opacity = '0';
                    card.style.transform = 'translateY(20px)';
                    
                    setTimeout(() => {
                        card.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
                        card.style.opacity = '1';
                        card.style.transform = 'translateY(0)';
                    }, 50 * index);
                });
            }, 100);
        });
    </script>
</script>
